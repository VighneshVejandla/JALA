# Base URL the SPA calls for the JALA backend API.
# Same-origin (Spring serves the built SPA, or `npm run dev` proxy): leave as /api/v1
# Cross-origin deploy: set to the full backend URL, e.g. https://api.jala.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# Dev only: origin the `npm run dev` proxy forwards /api to. Defaults to http://localhost:8080
VITE_DEV_BACKEND=http://localhost:8080
