# Copy to .env.properties (or export as environment variables).
# NEVER commit real values.

# Which profile to boot: dev (local) or prod (deployment).
SPRING_PROFILES_ACTIVE=dev

# --- Database (dev profile: assembled as jdbc:postgresql://HOST:PORT/NAME) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jala
DB_USERNAME=jala
DB_PASSWORD=change-me

# --- Database (prod profile: full JDBC URL, separate from SUPABASE_URL) ---
# DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres

# Optional Hikari pool size override (default 20)
# DB_POOL_SIZE=20

# --- JWT ---
# High-entropy secret, at least 32 bytes. Generate: openssl rand -base64 48
JWT_SECRET=
# Access token lifetime in milliseconds (e.g. 3600000 = 1h)
JWT_EXPIRATION=3600000

# --- Supabase storage (REST base URL, not the JDBC URL) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# --- CORS: comma-separated browser origins allowed to call the API ---
# CORS_ALLOWED_ORIGINS=https://app.example.com
